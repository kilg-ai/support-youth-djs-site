---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const questions = [
  { title: "What should a new DJ practice first?", text: "Start with clean transitions, music organization, and recording short practice sets. Fancy tricks make more sense after the basics sound steady." },
  { title: "When is it time to upgrade equipment?", text: "Upgrade when the current setup blocks a real need. Better practice, cleaner crates, and stronger preparation often matter before new gear." },
  { title: "How should a youth DJ share work publicly?", text: "Use approved public links, keep private contact information off the site, and make sure a parent or legal guardian understands what is being shared." }
];
---

<BaseLayout title="Questions & Answers" description="Editorial DJ questions, answers, interviews, and multiple perspectives for Support Youth DJs.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Questions & Answers</p><h1>Real questions. Useful answers.</h1><p class="lead">Phase 1 Q&A is created and managed by the editorial team.</p></div></section>
  <section class="section"><div class="section-inner"><div class="grid">{questions.map((item, index) => <article class:list={["panel", index === 0 ? "red" : ""]}><h3>{item.title}</h3><p>{item.text}</p></article>)}</div><CTA title="No Public Posting Yet" text="No comments, forums, public answer submission, or user accounts are part of Phase 1." href="/learn/" label="Learn" /></div></section>
</BaseLayout>
