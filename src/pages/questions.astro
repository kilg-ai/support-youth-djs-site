---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const questions = [
  { title: "How do youth DJs prepare for real bookings?", text: "Answers can connect client communication, set preparation, clean music, parent involvement, pricing questions, expectations, and recovery when plans change." },
  { title: "When is it time to upgrade equipment?", text: "Equipment questions should connect to real needs, technical problems, performance goals, budget, practice habits, and related resources." },
  { title: "How should a youth DJ share public work?", text: "Public work can connect directory profiles, social links, mixes, videos, Spotlight stories, learning topics, city or state, and related contributors." }
];
---

<BaseLayout title="Questions & Answers" description="Editorial DJ questions, answers, interviews, and connected perspectives for Support Youth DJs.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Questions & Answers</p><h1>Questions connect the platform.</h1><p class="lead">Questions and perspectives can connect DJ profiles, Spotlight articles, learning topics, resources, programs, cities, states, genres, and contributors. Phase 1 Q&A is editorially managed.</p></div></section>
  <section class="section"><div class="section-inner"><div class="grid">{questions.map((item, index) => <article class:list={["panel", index === 0 ? "red" : ""]}><h3>{item.title}</h3><p>{item.text}</p></article>)}</div><CTA title="Editorial Phase" text="Phase 1 uses selected questions and reviewed answers before anything is published." href="/learn/" label="Learn" /></div></section>
</BaseLayout>
