---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms" description="Terms overview for Support Youth DJs campaign participation, merch, affiliate links, and youth DJ features.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Terms</p>
      <h1>Terms Overview</h1>
      <p class="lead">Support Youth DJs is a community campaign and merch project operated by Ryan the 1 LLC.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="grid">
        <article class="panel red">
          <h2>No Guarantees</h2>
          <p>Participation, features, partnerships, submissions, or purchases do not guarantee bookings, sponsorships, media coverage, exposure, or career outcomes.</p>
        </article>
        <article class="panel">
          <h2>Youth Features</h2>
          <p>Minors require parent/legal guardian consent before public features. Youth DJs under 13 require direct parent/legal guardian involvement in submission, video, and approval.</p>
        </article>
        <article class="panel">
          <h2>Merch</h2>
          <p>Merch purchases support the campaign as purchases, not donations. Do not treat purchases as tax-deductible support.</p>
        </article>
        <article class="panel">
          <h2>Affiliate Links</h2>
          <p>Some links may be affiliate links. The campaign may earn a commission if you purchase through those links, at no extra cost to you.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
