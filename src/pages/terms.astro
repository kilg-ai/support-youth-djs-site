---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Terms" description="Terms overview for Support Youth DJs directory participation, merchandise, affiliate links, and youth DJ features.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Terms</p>
      <h1>Terms Overview</h1>
      <p class="lead">Support Youth DJs is a youth DJ directory, learning resource, and culture platform operated by Ryan the 1 LLC.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="grid">
        <article class="panel red"><h2>No Guarantees</h2><p>Participation, features, partnerships, submissions, or purchases do not guarantee bookings, sponsorships, media coverage, exposure, followers, income, or career outcomes.</p></article>
        <article class="panel"><h2>Directory Eligibility</h2><p>The public directory is for DJs under 18. Adult DJs may use learning resources and contribute through interviews, advice, and public resources, but are not directory members.</p></article>
        <article class="panel"><h2>Public Links Only</h2><p>Directory submissions use public URLs and moderation. Private contact information, home addresses, schools, exact birth dates, and private schedules should not be submitted for publication.</p></article>
        <article class="panel"><h2>Merch and Affiliate Links</h2><p>Merch purchases are product purchases, not donations. Some links may be affiliate links, and we may earn a commission at no extra cost to you.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
