---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Privacy" description="Privacy overview for Support Youth DJs directory submissions, contact, merchandise, and affiliate activity.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Privacy</p>
      <h1>Privacy Overview</h1>
      <p class="lead">Support Youth DJs should collect only what is needed to review directory submissions, answer messages, maintain public resources, and run the platform responsibly.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="grid">
        <article class="panel"><h2>Submissions</h2><p>Submission forms may ask for public DJ name, age range, city, state, genres, public links, submitter role, private administrative email, and consent acknowledgements. Media should be submitted as public URLs only.</p></article>
        <article class="panel"><h2>Contact</h2><p>Emails sent to {site.contactEmail} or {site.shopEmail} may be used to respond to directory, shop, parent, submission, partner, or affiliate questions.</p></article>
        <article class="panel"><h2>Shop</h2><p>Merch checkout may happen through an external provider after commerce is approved. Their privacy, payment, shipping, and refund rules may apply.</p></article>
        <article class="panel"><h2>Affiliate Links</h2><p>Some links may be affiliate links. Affiliate platforms may track clicks or purchases according to their own policies.</p></article>
      </div>
      <ul class="list"><li>Do not submit private school, home address, private schedule, phone number, or sensitive family information for a youth DJ profile.</li><li>No file uploads are accepted through the Phase 1 directory intake.</li><li>Parents/legal guardians can contact Support Youth DJs with questions before a public feature is approved.</li><li>This privacy overview should be reviewed before large-scale submissions or paid advertising begin.</li></ul>
    </div>
  </section>
</BaseLayout>
