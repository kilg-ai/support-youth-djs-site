---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Privacy" description="Privacy overview for Support Youth DJs submissions, contact, merch, and affiliate activity.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Privacy</p>
      <h1>Privacy Overview</h1>
      <p class="lead">Support Youth DJs should collect only what is needed to review submissions, answer messages, support merch, and run the campaign responsibly.</p>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <div class="grid">
        <article class="panel">
          <h2>Submissions</h2>
          <p>Submission forms may ask for youth DJ details, parent/legal guardian contact, links, photos, videos, and approval notes. Minors require parent/legal guardian consent before public features.</p>
        </article>
        <article class="panel">
          <h2>Contact</h2>
          <p>Emails sent to {site.contactEmail} or {site.shopEmail} may be used to respond to campaign, shop, parent, submission, partner, or affiliate questions.</p>
        </article>
        <article class="panel">
          <h2>Shop</h2>
          <p>Merch checkout may happen through an external provider. Their privacy, payment, shipping, and refund rules may apply.</p>
        </article>
        <article class="panel">
          <h2>Affiliate Links</h2>
          <p>Some links may be affiliate links. Affiliate platforms may track clicks or purchases according to their own policies.</p>
        </article>
      </div>
      <ul class="list">
        <li>Do not submit private school, home address, private schedule, or sensitive family information for a youth DJ feature.</li>
        <li>Parents/legal guardians can contact the campaign with questions before a public feature is approved.</li>
        <li>This starter page should be reviewed before large-scale submissions or paid advertising begin.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
