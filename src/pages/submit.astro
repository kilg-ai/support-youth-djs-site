---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const focusOptions = ["Learning the basics", "Practicing transitions", "Organizing music", "Preparing to play in public", "Improving crowd interaction", "Improving performance", "Upgrading equipment", "Building a brand", "Learning production", "Sharing knowledge"];
---

<BaseLayout title="Join the Directory" description="Join the Support Youth DJs directory with link-based submissions, age rules, consent, and moderation.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Join the Directory</p><h1>Submit public DJ links.</h1><p class="lead">The directory is exclusively for DJs under 18. All submitted public material must be URL-based and reviewed before publication.</p></div></section>
  <section class="section"><div class="section-inner">
    <h2>Who is submitting this DJ profile?</h2>
    <div class="grid"><article class="panel red"><h3>I am a DJ age 13-17.</h3><p>DJs ages 13-17 may initiate their own directory submission using public links and a private administrative email.</p></article><article class="panel"><h3>I am a parent or legal guardian.</h3><p>Profiles for DJs under 13 must be initiated and managed by a parent or legal guardian.</p></article><article class="panel"><h3>Age 18 or older?</h3><p>The directory is exclusively for DJs under 18. Adult DJs are welcome to use learning resources and contribute through interviews, advice, and public resources.</p></article></div>
    <h2>Submission Rules</h2>
    <ul class="list"><li>No file uploads. Submit public URLs only.</li><li>No private phone numbers, private emails, home addresses, schools, exact birth dates, or private schedules are published.</li><li>Visitors contact or follow DJs only through the public links selected for the profile.</li><li>Every submission enters moderation before publication.</li></ul>
    <h2>Current Focus Options</h2>
    <div class="filter-row">{focusOptions.map((item) => <span>{item}</span>)}</div>
    <CTA title="Directory Intake" text="Use the contact email while the moderated intake form is being finalized. Send public links only and do not include private personal information." href="/contact/" label="Contact" />
  </div></section>
</BaseLayout>

<style>.filter-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}.filter-row span{border:2px solid var(--ink);color:var(--ink);font-family:Arial,Helvetica,sans-serif;font-weight:800;padding:12px 14px;text-transform:uppercase}</style>
