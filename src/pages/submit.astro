---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import FeatureGrid from "../components/FeatureGrid.astro";

const workflow = [
  { title: "1. Check eligibility", text: "The directory is for DJs under 18. Ages 13-17 may initiate their own directory submission. DJs under 13 require a parent or legal guardian to submit." },
  { title: "2. Send public links", text: "Submit public URLs only, such as mixes, public videos, social profiles, official pages, or other public work selected for review." },
  { title: "3. Editorial review", text: "A submitted profile is reviewed before anything is published. Directory participation is separate from Spotlight or editorial features." },
  { title: "4. Correction or removal", text: "Published directory information can be corrected or removed by contacting the platform with the profile details." }
];

const rules = [
  "Directory participation is separate from Spotlight consideration.",
  "DJs ages 13-17 may initiate submissions using public links.",
  "DJs under 13 require parent or legal guardian submission.",
  "Adults are not eligible for directory profiles.",
  "Public URLs only. No uploads are accepted.",
  "No automatic publication. Every profile is reviewed first.",
  "Private phone numbers, private emails, home addresses, schools, exact birth dates, and private schedules are not published."
];
---

<BaseLayout title="Join the Directory" description="Join the Support Youth DJs directory with public-link submissions, age routing, moderation, and correction or removal options.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Join the Directory</p><h1>Join a growing record of youth DJ culture.</h1><p class="lead">The directory is for youth DJs under 18 who want approved public work, city and state, genres, and related culture links reviewed for possible publication.</p></div></section>
  <section class="section"><div class="section-inner">
    <h2>Directory Workflow</h2>
    <FeatureGrid items={workflow} />
    <h2>Rules Before You Send Links</h2>
    <ul class="list">{rules.map((item) => <li>{item}</li>)}</ul>
    <CTA title="Start With Contact" text="Use the contact email for directory help. Send public links only and do not include private personal information." href="/contact/" label="Contact" />
  </div></section>
</BaseLayout>
