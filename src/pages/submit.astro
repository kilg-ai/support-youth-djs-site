---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout title="Submit" description="Submission information for youth DJs 13+ with parent or legal guardian consent requirements.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Submit</p>
      <h1>Submit a Youth DJ</h1>
      <p class="lead">Youth DJs 13+ may be submitted for spotlight consideration. The submission path is built around parent approval, clean content, and clear expectations.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner">
      <h2>Consent First</h2>
      <ul class="list">
        <li>Minors require parent/legal guardian consent before public features.</li>
        <li>Youth DJs under 13 require direct parent/legal guardian involvement in submission, video, and approval.</li>
        <li>Submissions are reviewed for fit, safety, and approval before anything is public.</li>
        <li>Features, submissions, or purchases do not guarantee bookings, sponsorships, media coverage, or career outcomes.</li>
      </ul>
      <div class="grid submit-grid">
        <article class="panel red">
          <h3>What to Prepare</h3>
          <p>Youth DJ name, age, city, parent/legal guardian contact, clean video links, short bio, and permission to review.</p>
        </article>
        <article class="panel">
          <h3>What Happens Next</h3>
          <p>Submissions are reviewed before public use. Parent approval is required before any profile, clip, or story goes live.</p>
        </article>
      </div>
      <CTA title="Submission Form Coming Next" text="A form link can be added after privacy language, consent fields, and review steps are finalized." href="/parents/" label="Parent Info" />
    </div>
  </section>
</BaseLayout>
