---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Contact" description="Contact Support Youth DJs about directory help, profile correction or removal, editorial contributions, programs, resources, general questions, and merchandise support.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Contact</p><h1>Contact</h1><p class="lead">Use the official emails for directory help, profile correction or removal, editorial contributions, programs, resources, general questions, and merchandise support.</p></div></section>
  <section class="section"><div class="section-inner"><div class="grid"><article class="panel red"><h2>Platform Contact</h2><p><a class="text-link" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p><p>Directory help, public-link submissions, parent questions, profile correction, profile removal, editorial ideas, programs, resources, contributors, and general platform questions.</p></article><article class="panel"><h2>Merchandise Support</h2><p><a class="text-link" href={`mailto:${site.shopEmail}`}>{site.shopEmail}</a></p><p>Merchandise questions only. Checkout is not active until product and policy details are approved.</p></article></div></div></section>
</BaseLayout>
