---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="Contact" description="Contact Support Youth DJs using the official contact and shop email addresses.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Contact</p>
      <h1>Contact</h1>
      <p class="lead">Use the official emails for campaign and shop questions.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner">
      <div class="grid">
        <article class="panel">
          <h2>Campaign</h2>
          <p><a class="text-link" href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p>
        </article>
        <article class="panel">
          <h2>Shop</h2>
          <p><a class="text-link" href={`mailto:${site.shopEmail}`}>{site.shopEmail}</a></p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
