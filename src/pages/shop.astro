---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";

const auditItems = [
  "Product data",
  "Images",
  "Pricing",
  "Sizes and variants",
  "Inventory or fulfillment",
  "Shipping",
  "Taxes",
  "Return and refund policy",
  "Checkout security",
  "Analytics"
];
---

<BaseLayout title="Official Merch" description="Official Support Youth DJs merchandise information with checkout inactive until commerce is audited and approved.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Official Merch</p>
      <h1>Wear the message.</h1>
      <p class="lead">Support Youth DJs T-shirt promotion is being prepared. Checkout is inactive until product, fulfillment, policy, and checkout details are audited and approved.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner">
      <div class="shop-board">
        <div>
          <p class="kicker">Product purchase, not a donation.</p>
          <h2>Support Youth DJs T-shirt</h2>
          <p>No public checkout link is active in Phase 1. Merchandise should support the mission without becoming the main identity of the platform.</p>
        </div>
        <img src="/assets/support-youth-djs-logo.png" alt="Support Youth DJs logo" />
      </div>
      <ul class="list">
        {auditItems.map((item) => <li>{item} must be confirmed before Phase 2 commerce activation.</li>)}
      </ul>
      <CTA title="Phase 2 Required" text="Do not activate T-shirt checkout until the commerce audit is reviewed and approved by the owner." href="/resources/" label="Resources" />
    </div>
  </section>
</BaseLayout>

<style>
  .shop-board {
    align-items: center;
    background: var(--paper);
    color: var(--bg);
    display: grid;
    gap: 22px;
    padding: clamp(22px, 5vw, 48px);
  }

  .shop-board p { color: #171717; }

  .shop-board img {
    justify-self: center;
    max-width: min(360px, 78vw);
    width: 100%;
  }

  @media (min-width: 820px) {
    .shop-board { grid-template-columns: 1fr 320px; }
  }
</style>
