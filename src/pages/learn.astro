---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import CTA from "../components/CTA.astro";

const topics = [
  { title: "Bookings", text: "Preparing for real gigs, expectations, communication, parent involvement, pricing questions, and recovery when something changes." },
  { title: "Performance", text: "Crowd reading, clean edits, transitions, energy control, setup checks, and what to do when a set does not go as planned." },
  { title: "Music Preparation", text: "Crates, clean versions, event notes, backups, genres, energy levels, and the prep that makes public work stronger." },
  { title: "Equipment", text: "Controllers, headphones, speakers, cases, cables, software, upgrades, technical problems, and what can wait." },
  { title: "Marketing and Business", text: "Public profiles, social links, client communication, pricing, branding, professionalism, and youth-specific realities." },
  { title: "Community", text: "Competition, respect, local scenes, cultural history, contributors, programs, different paths into DJing, and continuing development." }
];
---

<BaseLayout title="Learn" description="Practical DJ knowledge connected to youth DJ culture, profiles, questions, stories, and resources.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Learn</p><h1>Learn from real DJ experience.</h1><p class="lead">Learning is open to everyone. The directory is exclusively for DJs under 18. The knowledge base connects profiles, questions, Spotlight stories, resources, programs, contributors, cities, states, and genres.</p></div></section>
  <section class="section"><div class="section-inner"><FeatureGrid items={topics} /><CTA title="Questions and Perspectives" text="Questions can connect practical problems to youth DJs, experienced contributors, related stories, resources, and learning topics." href="/questions/" label="Read Q&A" /></div></section>
</BaseLayout>
