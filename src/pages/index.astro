---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import { site } from "../data/site";

const participation = [
  { title: "Join the directory", text: "Add to a growing record of youth DJ culture with public links, city and state, genres, mixes, videos, and related stories." },
  { title: "Share public work", text: "Profiles can connect to public sets, social links, mixes, videos, questions, learning topics, and related resources after review." },
  { title: "Contribute to the culture", text: "Youth DJs, experienced contributors, programs, and supporters can help build a stronger network around youth DJ culture." }
];

const experience = [
  { title: "Real DJ experience", text: "Practical knowledge can come from bookings, equipment decisions, performance, music preparation, client communication, pricing, mistakes, and recovery." },
  { title: "Questions and perspectives", text: "The platform can connect questions, answers, interviews, related profiles, genres, cities, states, and learning topics." },
  { title: "Youth-specific realities", text: "Content can document different paths into DJing, family boundaries, school schedules, competition, community, and continuing development." }
];

const learningTopics = [
  { title: "Performance", text: "Crowd reading, set preparation, transitions, clean edits, setup checks, and recovering when something goes wrong." },
  { title: "Music Preparation", text: "Crates, clean versions, energy levels, backups, event notes, and the habits that make public sets stronger." },
  { title: "Business Basics", text: "Client communication, pricing questions, marketing, expectations, parent involvement, and professional boundaries." },
  { title: "Equipment", text: "Controllers, headphones, speakers, cases, cables, software, upgrades, and what can wait until later." }
];

const cultureLinks = [
  { title: "Youth DJ programs", text: "Space for programs, workshops, educators, local scenes, and movements supported by public information." },
  { title: "Community resources", text: "Resources can point to people doing the work without implying formal partnership, endorsement, legal review, or formal approval." },
  { title: "Advocacy foundation", text: "We create space for youth DJs to be heard, identify shared needs, and advocate from what the culture tells us." }
];
---

<BaseLayout title={site.name} description="Support Youth DJs is building a shared platform for youth DJ culture.">
  <section class="hero">
    <div class="hero-inner">
      <p class="stamp">The Culture. The Future.</p>
      <h1>Support Youth DJs</h1>
      <p class="lead">Support Youth DJs is building a shared platform for youth DJ culture.</p>
      <p class="kicker">Join the directory. Share public work. Learn from real DJ experience. Explore youth DJ culture. Contribute to the culture.</p>
      <div class="actions">
        <a class="button primary" href="/submit/">Join the Directory</a>
        <a class="button" href="/djs/">Directory</a>
        <a class="button" href="/learn/">Learn</a>
        <a class="button" href="/spotlight/">Explore Spotlight</a>
      </div>
    </div>
  </section>

  <section class="section"><div class="section-inner"><p class="stamp">Join</p><h2>Join a growing record of youth DJ culture.</h2><p class="lead">The directory is participation first. Discovery is one benefit of adding approved public work, city and state, genres, related questions, stories, learning topics, and resources.</p><FeatureGrid items={participation} /><CTA title="Directory Intake" text="DJs ages 13-17 may initiate submissions. DJs under 13 require parent or legal guardian submission. All submissions are links-only and reviewed before publication." href="/submit/" label="Join" /></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Profiles</p><h2>Featured youth DJs will connect across the platform.</h2><article class="panel red"><h3>Founding profiles are being reviewed</h3><p>Published profiles can connect to public sets, mixes, videos, social links, questions, Spotlight stories, learning topics, city or state pages, genres, programs, resources, and other relevant youth DJs.</p></article></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Experience</p><h2>Real DJ experience belongs in the knowledge base.</h2><FeatureGrid items={experience} /></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Questions</p><h2>Questions and perspectives connect the culture.</h2><p class="lead">Editorial questions can connect youth DJs, experienced contributors, genres, cities, equipment choices, mistakes, recovery, business realities, and practical learning.</p><div class="actions"><a class="button" href="/questions/">Questions & Answers</a><a class="button" href="/learn/">Learning Topics</a></div></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Learn</p><h2>Practical DJ knowledge.</h2><FeatureGrid items={learningTopics} /></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Spotlight</p><h2>Profiles, public work, and stories.</h2><p class="lead">Spotlight is editorial and separate from directory eligibility. It can connect public work, lessons learned, related questions, learning topics, resources, and youth DJ movements.</p><CTA title="Explore Spotlight" text="Spotlight can document public sets, interviews, equipment decisions, booking experiences, mistakes, recovery, community, and different paths into DJing." href="/spotlight/" label="Spotlight" /></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Culture</p><h2>Programs, movements, scenes, and resources.</h2><FeatureGrid items={cultureLinks} /></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Resources</p><h2>Connected resources for youth DJ culture.</h2><p class="lead">Resources can connect to learning topics, profiles, Spotlight stories, programs, genres, contributors, cities, states, and repeated needs from the culture.</p><a class="button" href="/resources/">Resources</a></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Advocacy</p><h2>Advocacy starts with listening.</h2><p class="lead">We create space for youth DJs to be heard, identify shared needs, and advocate from what the culture tells us. Support Youth DJs does not claim to represent all youth DJs.</p></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Official Merch</p><h2>Wear the message. Support Youth DJs.</h2><p class="lead">T-shirt promotion stays secondary while the platform remains directory, culture, and knowledge first. Checkout remains inactive until commerce is audited and approved.</p><a class="button" href="/shop/">Merch Info</a></div></section>

  <section class="section"><div class="section-inner"><p class="stamp">Mission</p><h2>Support Youth DJs.</h2><p class="lead">The Culture. The Future. Building a stronger network around youth DJ culture.</p><CTA title="Contribute to the Culture" text="Join the directory, share public work, learn from real experience, point us toward programs, and help document what youth DJs are building." href="/submit/" label="Join the Directory" /></div></section>
</BaseLayout>
