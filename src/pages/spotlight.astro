---
import BaseLayout from "../layouts/BaseLayout.astro";
import YouthProfileCard from "../components/YouthProfileCard.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout title="Spotlight" description="Support Youth DJs spotlights youth DJ profiles, videos, interviews, practice clips, gear notes, and performance stories with parent approval.">
  <section class="page-head">
    <div class="page-head-inner">
      <p class="stamp">Spotlight</p>
      <h1>Young DJs on the Rise</h1>
      <p class="lead">Profiles, videos, interviews, practice clips, gear notes, and performance stories, published only with the right approval.</p>
    </div>
  </section>
  <section class="section">
    <div class="section-inner">
      <div class="grid">
        <YouthProfileCard name="Feature Profile" detail="Approved youth DJ story with name, city, style, first setup, and what they are practicing now." note="Parent/legal guardian approval required before public features." />
        <YouthProfileCard name="Practice Clip" detail="Short-form video space for clean practice clips, blends, routines, scratches, and crowd-safe edits." note="Youth DJs under 13 require direct parent/legal guardian involvement." />
        <YouthProfileCard name="Gear Notes" detail="Beginner-friendly notes on controllers, headphones, crates, laptop setup, software, and practice habits." note="Gear links may include affiliate links when approved." />
      </div>
      <CTA title="Submit for Consideration" text="Youth DJs 13+ may be submitted for spotlight consideration. Minors require parent/legal guardian consent before public features." href="/submit/" label="Start Submission" />
    </div>
  </section>
</BaseLayout>
