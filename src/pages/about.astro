import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Support Youth DJs, the youth-led directory and learning community for DJs under 18.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">About</p><h1>About Support Youth DJs</h1><p class="lead">Support Youth DJs is a youth-led directory and learning community that helps DJs under 18 share their public work, get discovered, learn from DJ culture, and keep growing.</p></div></section>
  <section class="section"><div class="section-inner">
    <div class="grid">
      <article class="panel red"><h3>The Directory</h3><p>The directory helps people discover DJs under 18 through approved public links, city and state browsing, and moderated profile pages. Profiles are not rankings, ratings, or student records.</p></article>
      <article class="panel"><h3>Learning</h3><p>Learning content is open to everyone and stays connected to practical DJ decisions: practice, music organization, performance, equipment, branding, and business basics.</p></article>
      <article class="panel"><h3>Youth-Led Perspective</h3><p>Ryan is a working youth DJ whose experiences and questions can contribute to the site without making him the whole platform.</p></article>
    </div>
    <ul class="list"><li>Support Youth DJs recognizes that competition and community can exist together.</li><li>Youth DJs should be respected as DJs, not treated as novelty performers.</li><li>The platform can point to other youth-DJ movements, programs, and resources without claiming ownership of the culture.</li></ul>
  </div></section>
</BaseLayout>
