---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTA from "../components/CTA.astro";
---

<BaseLayout title="Find DJs" description="Join a growing record of youth DJ culture through approved public profiles.">
  <section class="page-head"><div class="page-head-inner"><p class="stamp">Directory</p><h1>Join a growing record of youth DJ culture.</h1><p class="lead">The directory is participation, not a listing service. Profiles connect public work, city and state, genres, questions, Spotlight stories, learning topics, resources, and related youth DJ culture.</p></div></section>
  <section class="section"><div class="section-inner">
    <div class="grid">
      <article class="panel red"><h3>Founding profiles are being reviewed</h3><p>No youth DJs have been published yet. The first profiles will go live only after public links, age eligibility, consent needs, and moderation are complete.</p></article>
      <article class="panel"><h3>Profile connections</h3><p>Profiles may connect to public sets, social links, mixes, videos, questions, related stories, learning topics, city or state, programs, resources, and other relevant youth DJs.</p></article>
      <article class="panel"><h3>Under 18 only</h3><p>The public directory is for DJs under 18. Adult DJs may contribute editorially through interviews, advice, resources, and public knowledge.</p></article>
    </div>
    <CTA title="Join the Directory" text="DJs ages 13-17 may initiate submissions. Under-13 submissions require a parent or legal guardian. All submissions are links-only and reviewed before publication." href="/submit/" label="Join" />
  </div></section>
</BaseLayout>
