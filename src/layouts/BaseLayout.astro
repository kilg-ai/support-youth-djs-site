---
import { navItems } from "../data/nav";
import { site } from "../data/site";
import Disclaimer from "../components/Disclaimer.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const pageTitle = title === site.name ? title : `${title} | ${site.name}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#050505" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="Support Youth DJs home">
        <span class="brand-badge" aria-hidden="true"><span>Support</span><span>Youth</span><span>DJs</span></span>
        <span>{site.name}</span>
      </a>
      <nav aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>

    <main><slot /></main>

    <footer class="site-footer">
      <div class="footer-top">
        <span class="brand-badge footer-badge" aria-hidden="true"><span>Support</span><span>Youth</span><span>DJs</span></span>
        <div>
          <p>Support Youth DJs is operated by Ryan the 1 LLC.</p>
          <p class="footer-links"><a href="/privacy/">Privacy</a> <a href="/terms/">Terms</a></p>
        </div>
      </div>
      <Disclaimer />
    </footer>
  </body>
</html>

<style is:global>
  :root { color-scheme: dark; --bg: #050505; --ink: #ffffff; --muted: #d0d0d0; --line: #2d2d2d; --paper: #f8f4e8; --accent: #c3161c; --accent-2: #ffffff; --gold: #e8c24c; --panel: #111111; font-family: "Arial Black", Arial, Helvetica, sans-serif; }
  * { box-sizing: border-box; }
  body { margin: 0; background: linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(180deg, rgba(255,255,255,0.02) 1px, transparent 1px), var(--bg); background-size: 28px 28px; color: var(--ink); letter-spacing: 0; min-width: 320px; }
  body::before { content: ""; position: fixed; inset: 0; pointer-events: none; background-image: radial-gradient(rgba(255,255,255,0.14) 0.7px, transparent 0.7px); background-size: 5px 5px; mix-blend-mode: screen; opacity: 0.18; }
  a { color: inherit; }
  .site-header { display: flex; flex-direction: column; gap: 18px; padding: 18px clamp(18px, 5vw, 56px); border-bottom: 4px solid var(--ink); background: #050505; position: sticky; top: 0; z-index: 10; }
  .brand { align-items: center; display: inline-flex; gap: 12px; font-size: 1.1rem; font-weight: 900; text-decoration: none; text-transform: uppercase; }
  .brand-badge { border: 2px solid var(--ink); display: grid; font-size: 0.76rem; gap: 1px; line-height: 1; min-height: 54px; min-width: 54px; padding: 7px 6px; place-items: center; text-align: center; text-transform: uppercase; transform: rotate(-2deg); }
  .footer-badge { min-height: 72px; min-width: 72px; font-size: 0.86rem; }
  nav { display: flex; flex-wrap: wrap; gap: 8px; }
  nav a, .button, .text-link { border: 2px solid var(--ink); color: var(--ink); display: inline-flex; font-size: 0.86rem; line-height: 1; padding: 12px 14px; text-decoration: none; text-transform: uppercase; transition: background 160ms ease, color 160ms ease, transform 160ms ease; }
  nav a:hover, .button:hover, .text-link:hover { background: var(--ink); color: var(--bg); transform: translateY(-2px); }
  .button.primary { background: var(--accent); border-color: var(--accent); color: var(--ink); }
  .button.primary:hover { background: var(--ink); border-color: var(--ink); color: var(--bg); }
  .hero, .section, .page-head { padding: clamp(46px, 9vw, 96px) clamp(18px, 5vw, 56px); }
  .hero { border-bottom: 4px solid var(--ink); min-height: 78vh; display: grid; align-content: center; gap: 26px; position: relative; overflow: hidden; }
  .hero::after { content: ""; background: radial-gradient(circle at center, transparent 0 17%, rgba(255,255,255,0.12) 18% 19%, transparent 20% 35%, rgba(255,255,255,0.08) 36% 37%, transparent 38% 100%); height: min(70vw, 760px); opacity: 0.32; position: absolute; right: -18vw; top: 50%; transform: translateY(-50%); width: min(70vw, 760px); z-index: -1; }
  .hero-inner, .section-inner, .page-head-inner { max-width: 1120px; width: 100%; }
  .stamp { background: var(--accent); color: var(--ink); display: inline-block; margin: 0 0 18px; padding: 8px 10px; text-transform: uppercase; transform: rotate(-2deg); }
  h1, h2, h3, p { margin-top: 0; }
  h1 { font-size: clamp(3rem, 14vw, 9rem); line-height: 0.88; margin-bottom: 20px; max-width: 980px; text-transform: uppercase; }
  h2 { font-size: clamp(2rem, 7vw, 4.8rem); line-height: 0.95; margin-bottom: 18px; text-transform: uppercase; }
  h3 { font-size: 1.25rem; line-height: 1.1; margin-bottom: 10px; text-transform: uppercase; }
  p, li, small { color: var(--muted); font-family: Arial, Helvetica, sans-serif; font-size: 1rem; line-height: 1.65; }
  .lead { color: var(--ink); font-size: clamp(1.18rem, 4vw, 1.9rem); line-height: 1.35; max-width: 780px; }
  .kicker { color: var(--gold); font-family: Arial, Helvetica, sans-serif; font-weight: 800; text-transform: uppercase; }
  .actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }
  .grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .panel, .profile-card, .cta-block { background: var(--panel); border: 2px solid var(--ink); box-shadow: 7px 7px 0 var(--accent); padding: 22px; }
  .panel.red { background: var(--accent); }
  .panel.red p, .panel.red small { color: var(--ink); }
  .profile-card { display: flex; gap: 18px; }
  .record-mark { aspect-ratio: 1; background: radial-gradient(circle, var(--ink) 0 8%, transparent 9% 19%, var(--ink) 20% 23%, transparent 24% 100%); border: 2px solid var(--ink); border-radius: 50%; flex: 0 0 70px; }
  .cta-block { align-items: start; display: grid; gap: 22px; margin-top: 28px; }
  .list { display: grid; gap: 12px; list-style: none; margin: 24px 0 0; padding: 0; }
  .list li { border-left: 6px solid var(--accent); background: #0d0d0d; padding: 14px 16px; }
  .site-footer { border-top: 4px solid var(--ink); padding: 28px clamp(18px, 5vw, 56px); }
  .footer-top { align-items: center; display: flex; gap: 18px; margin-bottom: 18px; }
  .footer-links { display: flex; gap: 12px; }
  .disclaimers { display: grid; gap: 6px; max-width: 1080px; }
  .disclaimers p, .site-footer p { font-size: 0.88rem; }
  @media (min-width: 820px) { .site-header { align-items: center; flex-direction: row; justify-content: space-between; } .cta-block { align-items: center; grid-template-columns: 1fr auto; } }
</style>
